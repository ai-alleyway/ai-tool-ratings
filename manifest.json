{
  "manifest_version": 3,
  "name": "AI Alleyway — AI Tool Reviews, Picks & Guides",
  "version": "1.1.0",
  "description": "Search independent AI-tool reviews, top picks, and buying guides from AI Alleyway — ratings and verdicts, one click away.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Tool Ratings",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "omnibox": {
    "keyword": "aa"
  },
  "permissions": []
}
