{
  "manifest_version": 3,
  "name": "AI Tool Ratings — by AI Alleyway",
  "version": "1.0.0",
  "description": "Search independent, hands-on ratings and one-line verdicts for popular AI tools. Reviewed by AI Alleyway.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Tool Ratings",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "omnibox": {
    "keyword": "aa"
  },
  "permissions": []
}
